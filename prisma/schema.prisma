generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "mysql"
 url      = env("DATABASE_URL")
}

model Article {
 id Int @id @default(autoincrement())
 title String
 content String
 author String
 category Category @relation(fields: [categoryId], references: [id])
 categoryId Int
}

model Category {
 id Int @id @default(autoincrement())
 name String
 articles Article[]
}